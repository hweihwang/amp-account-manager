{
  "name": "amp-account-manager",
  "version": "0.1.4",
  "private": false,
  "description": "Desktop account manager and thread handoff assistant for Amp CLI.",
  "author": {
    "name": "hweihwang",
    "email": "hoangmaths96@gmail.com"
  },
  "main": "dist-electron/main.js",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hweihwang/amp-account-manager.git"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -k -n \"MAIN,RENDERER,ELECTRON\" -c \"yellow,cyan,magenta\" \"npm run dev:main\" \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:main": "tsup --watch --env.NODE_ENV=development",
    "dev:renderer": "vite dev --host --strictPort --port 5180",
    "dev:electron": "wait-on dist-electron/main.js dist-electron/preload.js http://localhost:5180 && cross-env ELECTRON_START_URL=http://localhost:5180 electron .",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsup --env.NODE_ENV=production",
    "build:renderer": "vite build",
    "dist": "npm run build && electron-builder --config electron-builder.yml",
    "start": "cross-env NODE_ENV=production electron .",
    "typecheck": "tsc --noEmit",
    "rebuild": "npx @electron/rebuild",
    "release:builder": "electron-builder --config electron-builder.yml --mac zip --linux AppImage --arm64 --x64 --publish always",
    "release:clear-notes": "node scripts/clear-github-release-notes.js",
    "release:cleanup": "node scripts/cleanup-github-releases.js",
    "homebrew:cask": "node scripts/generate-homebrew-cask.js",
    "homebrew:publish": "node scripts/publish-homebrew-tap.js",
    "release": "npm run build && npm run release:builder && npm run release:clear-notes && npm run release:cleanup && npm run homebrew:cask && npm run homebrew:publish"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.6.1",
    "electron-builder": "^25.1.8",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  }
}
